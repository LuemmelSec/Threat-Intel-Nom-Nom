# Database Configuration
POSTGRES_USER=darkweb
POSTGRES_PASSWORD=darkweb_password_change_me
POSTGRES_DB=darkweb_db

# Backend Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
DATABASE_URL=postgresql://darkweb:darkweb_password_change_me@postgres:5432/darkweb_db
REDIS_URL=redis://redis:6379/0

# Email Configuration (for email alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@darkweb.local

# Tor Proxy
TOR_PROXY=socks5h://tor:9050

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
